# Kopiere diese Datei zu .env. .env wird NICHT committet (siehe .gitignore).
# analyzer.py spricht jeden OpenAI-kompatiblen Endpoint an.

# --- Variante A: Lokales MLX (empfohlen, M4-nativ, kein Key, DSGVO-freundlich) ---
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
LLM_API_KEY=local

# --- Variante B: Lokales Ollama ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
# LLM_API_KEY=ollama

# --- Variante C: Groq (kostenloser Key, gehostet, schnell) ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...

# --- Variante D: OpenAI (kostenpflichtig) ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# LLM_TIMEOUT=60
